    #################################################################
    # Ergänzungen gemäß FIDDK Datenmodell – Identifikatoren & Zusatzfelder
    #################################################################

    # bibo:isbn (0..1) – grobe Formatprüfung
    sh:property [
        sh:path bibo:isbn ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:datatype xsd:string ;
        sh:pattern "^(?:97[89][ -]?)?(?:\\d[ -]?){9}[\\dX]$" ;
        sh:flags "i" ;
    ] ;

    # bibo:issn (0..1) – Format ####-###X
    sh:property [
        sh:path bibo:issn ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:datatype xsd:string ;
        sh:pattern "^\\d{4}-\\d{3}[\\dX]$" ;
        sh:flags "i" ;
    ] ;

    # bf:partNumber (0..1)
    sh:property [
        sh:path bf:partNumber ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] ;

    # bf:shelfMark (0..1)
    sh:property [
        sh:path bf:shelfMark ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] ;

    # bf:subtitle (0..*)
    sh:property [
        sh:path bf:subtitle ;
        sh:minCount 0 ;
    ] ;

    # dc:format (0..*)
    sh:property [
        sh:path dc:format ;
        sh:minCount 0 ;
    ] ;

    # dcterms:hasFormat (0..*)
    sh:property [
        sh:path dcterms:hasFormat ;
        sh:minCount 0 ;
    ] ;

    # dcterms:hasVersion (0..*)
    sh:property [
        sh:path dcterms:hasVersion ;
        sh:minCount 0 ;
    ] ;

    # edm:realizes (0..*)
    sh:property [
