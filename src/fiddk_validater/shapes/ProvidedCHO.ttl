        sh:minCount 0 ;
    ] ;

    # edm:isSuccessorOf (0..*)
    sh:property [
        sh:path edm:isSuccessorOf ;
        sh:minCount 0 ;
    ] ;

    # edm:wasPresentAt (0..*)
    sh:property [
        sh:path edm:wasPresentAt ;
        sh:minCount 0 ;
    ] ;

    # Wenn edm:type = "TEXT", dann muss mind. eine dc:language vorhanden sein
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Für Objekte mit edm:type = \"TEXT\" muss mindestens eine dc:language angegeben sein."@de ;
        sh:select """
          PREFIX dc:   <http://purl.org/dc/elements/1.1/>
          PREFIX edm:  <http://www.europeana.eu/schemas/edm/>

          SELECT $this
          WHERE {
            $this edm:type ?t .
            FILTER(STR(?t) = "TEXT")
            FILTER NOT EXISTS { $this dc:language ?lang }
          }
        """
    ] .
