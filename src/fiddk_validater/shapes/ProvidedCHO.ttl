@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> . 
@prefix dc:      <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix edm:     <http://www.europeana.eu/schemas/edm/> .
@prefix ore:     <http://www.openarchives.org/ore/terms/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix rdau:    <http://www.rdaregistry.info/Elements/u/> .
@prefix bibo:    <http://purl.org/ontology/bibo/> .
@prefix bf:      <http://id.loc.gov/ontologies/bibframe/> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .

@prefix fiddk-sh: <https://performing-arts.eu/shapes/fiddk/> .

#################################################################
# edm:ProvidedCHO
#################################################################

fiddk-sh:ProvidedCHOShape
    a sh:NodeShape ;
    sh:targetClass edm:ProvidedCHO ;

    # dc:contributor (0..*)
    sh:property [
        sh:path dc:contributor ;
        sh:minCount 0 ;
    ] ;

    # dc:coverage (0..*)
    sh:property [
        sh:path dc:coverage ;
        sh:minCount 0 ;
    ] ;

    # dc:creator (0..*)
    sh:property [
        sh:path dc:creator ;
        sh:minCount 0 ;
    ] ;

    # Mindestens eins von dc:title | dc:description ist Pflicht
    sh:or (
      [ sh:property [ sh:path dc:title ;       sh:minCount 1 ] ]
      [ sh:property [ sh:path dc:description ; sh:minCount 1 ] ]
    ) ;

    # dc:description (0..*) – Beschreibung ODER Titel muss vorhanden sein
    sh:property [
        sh:path dc:description ;
        sh:minCount 0 ;
    ] ;

    # dc:identifier (0..*)
    sh:property [
        sh:path dc:identifier ;
        sh:minCount 0 ;
        sh:datatype xsd:string ;
    ] ;

    # dc:language (0..*)
    sh:property [
        sh:path dc:language ;
        sh:minCount 0 ;
        sh:nodeKind sh:Literal ;
    ] ;

    # dc:publisher (0..*)
    sh:property [
        sh:path dc:publisher ;
        sh:minCount 0 ;
    ] ;

    # dc:relation (0..*)
    sh:property [
        sh:path dc:relation ;
        sh:minCount 0 ;
    ] ;

    # dc:rights (0..*)
    sh:property [
        sh:path dc:rights ;
        sh:minCount 0 ;
    ] ;

    # dc:source (0..*)
    sh:property [
        sh:path dc:source ;
        sh:minCount 0 ;
    ] ;

    # Mindestens eins von dc:subject | dc:type | dcterms:spatial | dcterms:temporal ist Pflicht
    sh:or (
      [ sh:property [ sh:path dc:subject ;       sh:minCount 1 ] ]
      [ sh:property [ sh:path dc:type ;          sh:minCount 1 ] ]
      [ sh:property [ sh:path dcterms:spatial ;  sh:minCount 1 ] ]
      [ sh:property [ sh:path dcterms:temporal ; sh:minCount 1 ] ]
    ) ;

    # dc:subject (0..*)
    sh:property [
        sh:path dc:subject ;
        sh:minCount 0 ;
    ] ;

    # dc:title (0..1)
    sh:property [
        sh:path dc:title ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:Literal ;
    ] ;

    # dc:type (0..*)
    sh:property [
        sh:path dc:type ;
        sh:minCount 0 ;
    ] ;

    # dcterms:alternative (0..*)
    sh:property [
        sh:path dcterms:alternative ;
        sh:minCount 0 ;
    ] ;

    # dcterms:created (0..*)
    sh:property [
        sh:path dcterms:created ;
        sh:minCount 0 ;
    ] ;

    # dcterms:extent (0..*)
    sh:property [
        sh:path dcterms:extent ;
        sh:minCount 0 ;
    ] ;

    # dcterms:hasPart (0..*)
    sh:property [
        sh:path dcterms:hasPart ;
        sh:minCount 0 ;
    ] ;

    # dcterms:isPartOf (0..*)
    sh:property [
        sh:path dcterms:isPartOf ;
        sh:minCount 0 ;
    ] ;

    # dcterms:issued (0..*)
    sh:property [
        sh:path dcterms:issued ;
        sh:minCount 0 ;
    ] ;

    # dcterms:medium (0..*)
    sh:property [
        sh:path dcterms:medium ;
        sh:minCount 0 ;
    ] ;

    # dcterms:provenance (0..*)
    sh:property [
        sh:path dcterms:provenance ;
        sh:minCount 0 ;
    ] ;

    # dcterms:references (0..*)
    sh:property [
        sh:path dcterms:references ;
        sh:minCount 0 ;
    ] ;

    # dcterms:spatial (0..*)
    sh:property [
        sh:path dcterms:spatial ;
        sh:minCount 0 ;
    ] ;

    # dcterms:tableOfContents (0..*)
    sh:property [
        sh:path dcterms:tableOfContents ;
        sh:minCount 0 ;
    ] ;

    # dcterms:temporal (0..*)
    sh:property [
        sh:path dcterms:temporal ;
        sh:minCount 0 ;
    ] ;

    # edm:currentLocation (0..1)
    sh:property [
        sh:path edm:currentLocation ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] ;

    # edm:type (1..1) mit kontrollierter Werteliste
    sh:property [
        sh:path edm:type ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "TEXT" "IMAGE" "SOUND" "VIDEO" "3D" ) ;
    ] ;

    # owl:sameAs (0..*)
    sh:property [
        sh:path <http://www.w3.org/2002/07/owl#sameAs> ;
        sh:minCount 0 ;
        sh:nodeKind sh:IRI ;
    ] ;

    #################################################################
    # Ergänzungen gemäß FIDDK Datenmodell – fehlende DCTERMS
    #################################################################

    # dcterms:isFormatOf (0..*)
    sh:property [
        sh:path dcterms:isFormatOf ;
        sh:minCount 0 ;
    ] ;

    # dcterms:isReferencedBy (0..*)
    sh:property [
        sh:path dcterms:isReferencedBy ;
        sh:minCount 0 ;
    ] ;

    # dcterms:isReplacedBy (0..*)
    sh:property [
        sh:path dcterms:isReplacedBy ;
        sh:minCount 0 ;
    ] ;

    # dcterms:isRequiredBy (0..*)
    sh:property [
        sh:path dcterms:isRequiredBy ;
        sh:minCount 0 ;
    ] ;

    # dcterms:isVersionOf (0..*)
    sh:property [
        sh:path dcterms:isVersionOf ;
        sh:minCount 0 ;
    ] ;

    # dcterms:replaces (0..*)
    sh:property [
        sh:path dcterms:replaces ;
        sh:minCount 0 ;
    ] ;

    # dcterms:requires (0..*)
    sh:property [
        sh:path dcterms:requires ;
        sh:minCount 0 ;
    ] ;

    #################################################################
    # Ergänzungen gemäß FIDDK Datenmodell – fehlende EDM Properties
    #################################################################

    # edm:hasMet (0..*)
    sh:property [
        sh:path edm:hasMet ;
        sh:minCount 0 ;
    ] ;

    # edm:incorporates (0..*)
    sh:property [
        sh:path edm:incorporates ;
        sh:minCount 0 ;
    ] ;

    # edm:isDerivativeOf (0..*)
    sh:property [
        sh:path edm:isDerivativeOf ;
        sh:minCount 0 ;
    ] ;

    # edm:isNextInSequence (0..*)
    sh:property [
        sh:path edm:isNextInSequence ;
        sh:minCount 0 ;
    ] ;

    # edm:isRelatedTo (0..*)
    sh:property [
        sh:path edm:isRelatedTo ;
        sh:minCount 0 ;
    ] ;

    # edm:isRepresentationOf (0..1)
    sh:property [
        sh:path edm:isRepresentationOf ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
    ] ;

    # edm:isSimilarTo (0..*)
    sh:property [
        sh:path edm:isSimilarTo ;
        sh:minCount 0 ;
    ] ;

