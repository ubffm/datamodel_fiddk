@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> . 
@prefix dc:      <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix edm:     <http://www.europeana.eu/schemas/edm/> .
@prefix ore:     <http://www.openarchives.org/ore/terms/> .
@prefix foaf:    <http://xmlns.com/foaf/0.1/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix rdau:    <http://www.rdaregistry.info/Elements/u/> .
@prefix bibo:    <http://purl.org/ontology/bibo/> .
@prefix bf:      <http://id.loc.gov/ontologies/bibframe/> .
@prefix wgs84_pos: <http://www.w3.org/2003/01/geo/wgs84_pos#> .

@prefix fiddk-sh: <https://performing-arts.eu/shapes/fiddk/> .

#################################################################
# ore:Aggregation
#################################################################

fiddk-sh:AggregationShape
    a sh:NodeShape ;
    sh:targetClass ore:Aggregation ;

    # edm:aggregatedCHO (1..1)
    sh:property [
        sh:path edm:aggregatedCHO ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;

    # edm:dataProvider (1..1)
    sh:property [
        sh:path edm:dataProvider ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # edm:hasView (0..*)
    sh:property [
        sh:path edm:hasView ;
        sh:minCount 0 ;
        sh:nodeKind sh:IRI ;
    ] ;

    # edm:intermediateProvider (0..*)
    sh:property [
        sh:path edm:intermediateProvider ;
        sh:minCount 0 ;
    ] ;

    # edm:isShownAt (0..1)
    sh:property [
        sh:path edm:isShownAt ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;

    # edm:isShownBy (0..1)
    sh:property [
        sh:path edm:isShownBy ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;

    # edm:object (0..1)
    sh:property [
        sh:path edm:object ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;

    # edm:provider (1..1)
    sh:property [
        sh:path edm:provider ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    # dc:rights (0..*)
    sh:property [
        sh:path dc:rights ;
        sh:minCount 0 ;
    ] ;

    # edm:rights (0..1)
    sh:property [
        sh:path edm:rights ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
    ] ;

    # Mindestens eines von edm:isShownAt oder edm:isShownBy ist erforderlich
    sh:or (
      [ sh:property [ sh:path edm:isShownAt ; sh:minCount 1 ] ]
      [ sh:property [ sh:path edm:isShownBy ; sh:minCount 1 ] ]
    ) .
